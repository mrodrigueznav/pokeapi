generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Supertype {
  Pokemon @map("Pokémon")
  Trainer
  Energy
}

enum PhysicalCopyStatus {
  available
  assigned
  loaned
  missing
  sold
}

enum DeckFormat {
  Standard
  Expanded
  Casual
}

enum DecklistStatus {
  complete
  incomplete
  invalid
}

enum DeckStatus {
  complete
  incomplete
  invalid
}

enum LocationType {
  binder
  deckbox
  bulk
  loan
  sale
  lost
  other
}

enum MovementType {
  added
  moved
  assigned
  unassigned
  loaned
  returned
}

enum BuyListPriority {
  low
  normal
  high
}

enum BuyListStatus {
  pending
  purchased
  cancelled
}

model CardCatalogItem {
  id              String   @id
  name            String
  supertype       Supertype
  subtypes        String[]
  types           String[]
  setId           String
  setName         String
  number          String
  rarity          String
  imageUrl        String
  imageUrlLarge   String?
  regulationMark  String?
  legalities      Json?
  rules           String[]

  inventoryItems InventoryItem[]
  decklistCards  DecklistCard[]
  buyListItems   BuyListItem[]

  @@map("card_catalog_items")
}

model Location {
  id   String       @id @default(uuid())
  name String
  type LocationType

  inventoryItems InventoryItem[]
  physicalCopies PhysicalCardCopy[]

  @@map("locations")
}

model InventoryItem {
  id              String   @id @default(uuid())
  catalogCardId   String
  playableCardKey String
  variant         String   @default("normal")
  finish          String   @default("non-holo")
  language        String   @default("EN")
  condition       String   @default("NM")
  quantity        Int
  locationId      String?
  notes           String?
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  catalogCard    CardCatalogItem    @relation(fields: [catalogCardId], references: [id])
  location       Location?          @relation(fields: [locationId], references: [id])
  physicalCopies PhysicalCardCopy[]
  movements      Movement[]

  @@map("inventory_items")
}

model PhysicalCardCopy {
  id              String             @id @default(uuid())
  inventoryItemId String
  status          PhysicalCopyStatus @default(available)
  assignedDeckId  String?
  locationId      String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  inventoryItem InventoryItem        @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  assignedDeck  Deck?                @relation(fields: [assignedDeckId], references: [id], onDelete: SetNull)
  location      Location?            @relation(fields: [locationId], references: [id])
  assignments   DeckCardAssignment[]
  movements     Movement[]

  @@map("physical_card_copies")
}

/// Template list of cards — does NOT use collection copies.
model Decklist {
  id        String         @id @default(uuid())
  name      String
  format    DeckFormat
  status    DecklistStatus @default(incomplete)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  cards        DecklistCard[]
  decks        Deck[]
  buyListItems BuyListItem[]

  @@map("decklists")
}

model DecklistCard {
  id              String @id @default(uuid())
  decklistId      String
  playableCardKey String
  catalogCardId   String
  quantity        Int

  decklist    Decklist             @relation(fields: [decklistId], references: [id], onDelete: Cascade)
  catalogCard CardCatalogItem      @relation(fields: [catalogCardId], references: [id])
  assignments DeckCardAssignment[]

  @@unique([decklistId, playableCardKey])
  @@map("decklist_cards")
}

/// Physical deck built from a decklist with collection copies assigned.
model Deck {
  id         String     @id @default(uuid())
  name       String
  decklistId String
  status     DeckStatus @default(incomplete)
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  decklist       Decklist             @relation(fields: [decklistId], references: [id], onDelete: Restrict)
  assignments    DeckCardAssignment[]
  assignedCopies PhysicalCardCopy[]
  movements      Movement[]
  buyListItems   BuyListItem[]

  @@map("decks")
}

model DeckCardAssignment {
  id             String @id @default(uuid())
  deckId         String
  decklistCardId String
  physicalCopyId String

  deck         Deck             @relation(fields: [deckId], references: [id], onDelete: Cascade)
  decklistCard DecklistCard     @relation(fields: [decklistCardId], references: [id], onDelete: Cascade)
  physicalCopy PhysicalCardCopy @relation(fields: [physicalCopyId], references: [id], onDelete: Cascade)

  @@unique([physicalCopyId])
  @@map("deck_card_assignments")
}

model Movement {
  id              String       @id @default(uuid())
  at              DateTime     @default(now())
  type            MovementType
  inventoryItemId String?
  physicalCopyId  String?
  deckId          String?
  from            String?
  to              String?
  note            String?

  inventoryItem InventoryItem?    @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  physicalCopy  PhysicalCardCopy? @relation(fields: [physicalCopyId], references: [id], onDelete: SetNull)
  deck          Deck?             @relation(fields: [deckId], references: [id], onDelete: SetNull)

  @@map("movements")
}

model BuyListItem {
  id                String          @id @default(uuid())
  catalogCardId     String
  cardName          String
  supertype         Supertype
  playableCardKey   String
  desiredQuantity   Int
  acquiredQuantity  Int             @default(0)
  priority          BuyListPriority @default(normal)
  status            BuyListStatus   @default(pending)
  sourceDeckId      String?
  sourceDecklistId  String?
  notes             String?
  addedAt           DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  catalogCard    CardCatalogItem @relation(fields: [catalogCardId], references: [id])
  sourceDeck     Deck?           @relation(fields: [sourceDeckId], references: [id], onDelete: SetNull)
  sourceDecklist Decklist?       @relation(fields: [sourceDecklistId], references: [id], onDelete: SetNull)

  @@index([playableCardKey, status, sourceDeckId])
  @@index([playableCardKey, status, sourceDecklistId])
  @@index([status])
  @@index([sourceDeckId])
  @@index([sourceDecklistId])
  @@map("buy_list_items")
}
